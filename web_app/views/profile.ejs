<!DOCTYPE html>
<html>
<head>
    <title>个人中心</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { 
            font-family: 'Segoe UI', sans-serif; margin: 0; padding: 0; 
            background: #121212; color: #ddd; min-height: 100vh;
        }
        
        .header { background: #1e1e1e; padding: 20px 40px; display: flex; align-items: center; border-bottom: 1px solid #333; }
        .logo { font-size: 20px; font-weight: bold; color: white; text-decoration: none; }
        
        .container { max-width: 1100px; margin: 40px auto; display: flex; gap: 40px; }
        
        /* 左侧用户信息卡片 */
        .left-panel { width: 300px; }
        .profile-card { 
            background: #1e1e1e; padding: 40px 20px; border-radius: 16px; text-align: center; 
            border: 1px solid #333; position: sticky; top: 40px;
        }
        .avatar { 
            width: 120px; height: 120px; background: linear-gradient(135deg, #00f260, #0575e6); 
            border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; 
            font-size: 50px; color: white; border: 4px solid #121212; 
        }
        .username { font-size: 24px; font-weight: bold; color: white; margin-bottom: 5px; }
        .bio { font-size: 13px; color: #888; margin: 15px 0; font-style: italic; }
        
        .menu-list { text-align: left; margin-top: 30px; }
        .menu-item { 
            display: block; padding: 12px 15px; color: #ccc; text-decoration: none; border-radius: 8px; 
            margin-bottom: 5px; transition: 0.2s; cursor: pointer;
        }
        .menu-item i { width: 25px; color: #31c27c; }
        .menu-item:hover { background: #2a2a2a; color: white; }
        /* 小模块：查看别人品味 / 分享我的链接 */
        .mini-module { background: #2a2a2a; padding: 12px; border-radius: 8px; margin: 10px 0; color: #ddd; }
        .mini-module input { background: #1e1e1e; border: 1px solid #444; color: #ddd; padding: 8px; border-radius: 6px; width: calc(100% - 90px); }
        .mini-module button { background: #31c27c; border: none; color: white; padding: 8px 12px; border-radius: 6px; cursor: pointer; }
        .mini-module small { color: #888; display: block; margin-top: 6px; }
        
        .logout-btn { display: block; margin-top: 30px; padding: 10px; border: 1px solid #ff4757; color: #ff4757; text-decoration: none; border-radius: 20px; transition: 0.2s; }
        .logout-btn:hover { background: #ff4757; color: white; }

        /* 右侧内容 */
        .main-content { flex: 1; background: #1e1e1e; border-radius: 16px; min-height: 600px; border: 1px solid #333; overflow: hidden; display: flex; flex-direction: column;}
        
        .tabs { display: flex; border-bottom: 1px solid #333; background: #252525; }
        .tab { flex: 1; padding: 20px; text-align: center; cursor: pointer; color: #888; font-weight: bold; transition: 0.2s; }
        .tab:hover { background: #2a2a2a; color: white; }
        .tab.active { color: #31c27c; border-bottom: 3px solid #31c27c; background: #1e1e1e; }
        
        .tab-content { display: none; padding: 0; flex: 1; overflow-y: auto; max-height: 800px; }
        .tab-content.active { display: block; }

        .song-item { display: flex; align-items: center; padding: 15px 20px; border-bottom: 1px solid #2a2a2a; transition: 0.2s; position: relative; }
        .song-item:hover { background: #2a2a2a; }
        .cover { width: 50px; height: 50px; border-radius: 6px; object-fit: cover; margin-right: 15px; }
        .info { flex: 1; }
        .title { font-weight: bold; color: white; text-decoration: none; }
        .artist { font-size: 12px; color: #888; margin-top: 4px; }
        .meta { font-size: 12px; color: #555; }
        
        .btn-del { margin-left: 15px; color: #444; cursor: pointer; transition: 0.2s; padding: 8px; border-radius: 50%; }
        .btn-del:hover { color: #ff4757; background: rgba(255, 71, 87, 0.1); }

        /* 底部操作栏 (添加到歌单) */
        .action-bar { padding: 20px; border-top: 1px solid #333; text-align: right; background: #252525; }
        .btn-add-playlist { 
            background: #31c27c; color: white; border: none; padding: 10px 20px; 
            border-radius: 30px; cursor: pointer; font-weight: bold; 
        }
        .btn-add-playlist:hover { background: #2caf6f; }

        /* 弹窗样式 */
        .modal { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #333; padding: 30px; border-radius: 10px; box-shadow: 0 0 50px rgba(0,0,0,0.8); z-index: 1000; display: none; text-align: center; color: white;}
        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 999; display: none; }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="logo"><i class="fas fa-arrow-left"></i> 返回首页</a>
    </div>

    <div class="container">
        <!-- 左侧 -->
        <div class="left-panel">
            <div class="profile-card">
                <% const pageUser = (typeof viewUser !== 'undefined' && viewUser) ? viewUser : user; %>
                <div class="avatar"><%= pageUser.username[0].toUpperCase() %></div>
                <h2><%= pageUser.username %></h2>
                <div class="bio" id="bio-text">" 音乐是流动的建筑 "</div>
                
                <div class="menu-list">
                    <% if (isOwner) { %>
                        <div class="menu-item" onclick="alert('上传功能开发中...')"><i class="fas fa-camera"></i> 上传头像</div>
                        <div class="menu-item" onclick="editBio()"><i class="fas fa-pen"></i> 修改听歌宣言</div>
                        <div class="menu-item" onclick="alert('歌单创建功能开发中...')"><i class="fas fa-list"></i> 我的歌单</div>

                        <!-- 是否公开歌单 开关（仅自己可见并控制） -->
                        <div class="mini-module">
                            <label style="display:flex; align-items:center; gap:8px;">
                                <input type="checkbox" id="publicPlaylists" onchange="setPublicPlaylists(this.checked)" <%= pageUser.public_playlists ? 'checked' : '' %> />
                                <span>公开我的歌单</span>
                            </label>
                            <small>开启后，访客可在你的个人页查看你的歌单</small>
                        </div>
                    <% } else { %>
                        <!-- 访客查看别人资料，仅显示公开状态 -->
                        <div class="mini-module">
                            <div style="font-weight:bold; margin-bottom:6px;">Ta的歌单是否公开：</div>
                            <div><%= pageUser.public_playlists ? '是（可查看）' : '否（私密）' %></div>
                            <small style="display:block; margin-top:8px; color:#aaa;">提示：你正在查看别人的主页，仅可查看公开内容，修改操作已被隐藏</small>
                        </div>
                    <% } %>

                    <!-- 新增模块：查看Ta的品味（输入链接/用户名并跳转） -->
                    <% if (isOwner) { %>
                    <div class="mini-module">
                        <div style="font-weight:bold; margin-bottom:8px;"><i class="fas fa-user-check"></i> 看看Ta的品味</div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <input id="otherLink" placeholder="输入Ta的链接或用户名（例：/profile/张三 或 张三）">
                            <button onclick="goToTaste()">跳转</button>
                        </div>
                        <small>支持完整链接、以 / 开头的内部链接或直接用户名</small>
                    </div>
                    <% } else { %>
                    <div class="mini-module">
                        <div style="font-weight:bold; margin-bottom:8px;"><i class="fas fa-user-check"></i> 查看Ta的品味</div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <input id="otherLink" disabled placeholder="已进入 Ta 的主页，禁止再次跳转">
                            <button disabled style="opacity:0.6; cursor:not-allowed;">跳转</button>
                        </div>
                        <small>已禁用：为防止复制或二次跳转，此功能在访客页面被禁用</small>
                    </div>
                    <% } %>

                    <!-- 新增模块：分享我的链接（仅当前用户可见/复制） -->
                    <% if (isOwner) { %>
                    <div class="mini-module">
                        <div style="font-weight:bold; margin-bottom:8px;"><i class="fas fa-share-alt"></i> 分享我的链接</div>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <input id="myShareLink" readonly value="<%= '/profile/' + encodeURIComponent((pageUser && pageUser.username) || user.username) %>">
                            <button onclick="shareMyLink()">复制链接</button>
                        </div>
                        <small>复制到剪贴板（仅前端实现）</small>
                    </div>
                    <% } %>

                    <div class="menu-item" onclick="showDonate()"><i class="fas fa-coffee"></i> call maker</div>
                </div>

                <a href="/logout" class="logout-btn">退出登录</a>
            </div>
        </div>

        <!-- 右侧 -->
        <div class="main-content">
            <div class="tabs">
                <div class="tab active" onclick="switchTab('history')"><i class="fas fa-history"></i> 最近播放</div>
                <div class="tab" onclick="switchTab('likes')"><i class="fas fa-heart"></i> 我喜欢的</div>
                <div class="tab" onclick="switchTab('comments')"><i class="fas fa-comment"></i> 我的评论</div>
            </div>

            <!-- 历史 -->
            <div id="history" class="tab-content active">
                <% history.forEach(function(s) { %>
                    <div class="song-item">
                        <img src="<%= s.image_url %>" class="cover spotify-fix" data-source="spotify" data-title="<%= s.title %>" data-artist="<%= s.artist %>" onerror="this.src='https://y.qq.com/mediastyle/global/img/cover_like.png'">
                        <div class="info">
                            <a href="/player/<%= s.song_id %>" class="title"><%= s.title %></a>
                            <div class="artist"><%= s.artist %></div>
                        </div>
                        <div class="meta"><%= new Date(s.created_at).toLocaleString() %></div>
                    </div>
                <% }); %>
            </div>

            <!-- 喜欢 -->
            <div id="likes" class="tab-content">
                <div style="padding-bottom: 80px;"> <!-- 留出底部按钮空间 -->
                    <% likes.forEach(function(s) { %>
                        <div class="song-item" id="like-<%= s.song_id %>">
                            <input type="checkbox" style="margin-right: 15px;"> <!-- 模拟多选 -->
                            <img src="<%= s.image_url %>" class="cover spotify-fix" data-source="spotify" data-title="<%= s.title %>" data-artist="<%= s.artist %>" onerror="this.src='https://y.qq.com/mediastyle/global/img/cover_like.png'">
                            <div class="info">
                                <a href="/player/<%= s.song_id %>" class="title"><%= s.title %></a>
                                <div class="artist"><%= s.artist %></div>
                            </div>
                            <% if (isOwner) { %>
                            <div class="btn-del" onclick="deleteItem('like', '<%= s.song_id %>', 'like-<%= s.song_id %>')"><i class="fas fa-trash"></i></div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
                <!-- 底部悬浮操作栏 -->
                <div class="action-bar" style="position: sticky; bottom: 0;">
                    <button class="btn-add-playlist" onclick="alert('已将选中歌曲添加到[默认歌单]')"><i class="fas fa-plus"></i> 将选中添加到歌单</button>
                </div>
            </div>

            <!-- 评论 -->
            <!-- Tab 3: 评论 -->
            <div id="comments" class="tab-content">
                <% myComments.forEach(function(c) { %>
                    <div class="comment-card" id="comment-<%= c.id %>">
                        <!-- 【修改这里】给歌名加上链接 -->
                        <div class="c-song">
                            评论了 
                            <a href="/player/<%= c.song_id %>" style="text-decoration: none; color: #31c27c; font-weight: bold;">
                                《<%= c.title %>》
                            </a>
                        </div>
                        
                        <div class="c-content"><%= c.content %></div>
                        <div class="meta" style="margin-top:5px;"><%= new Date(c.created_at).toLocaleString() %></div>
                        
                        <% if (isOwner) { %>
                        <div class="btn-del c-del" onclick="deleteItem('comment', '<%= c.id %>', 'comment-<%= c.id %>')">
                            <i class="fas fa-trash-alt"></i>
                        </div>
                        <% } %>
                    </div>
                <% }); %>
            </div>

    <!-- 赞赏弹窗 -->
    <div class="overlay" id="overlay" onclick="closeModal()"></div>
    <div class="modal" id="donateModal">
        <h3>☕ Thanks for supports!</h3>
        <p>Our journey is still ongoing...</p>
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=ThankYou" style="margin: 10px;">
        <br>
        <button onclick="closeModal()" style="padding:5px 20px; cursor:pointer;">关闭</button>
    </div>

    <script>
        // 当前页面路径（用于防止二次跳转/复制当前主页链接）
        const CURRENT_PROFILE_PATH = '<%= '/profile/' + encodeURIComponent(pageUser.username) %>';
        function switchTab(id) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(el => el.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function deleteItem(type, id, elemId) {
            if(!confirm("确定要删除吗？")) return;
            fetch('/api/delete_item', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: type, id: type === 'comment' ? id : null, songId: type === 'like' ? id : null })
            }).then(res => res.json()).then(data => {
                if(data.success) document.getElementById(elemId).remove();
            });
        }

        function editBio() {
            const bio = prompt("请输入新的听歌宣言：", document.getElementById('bio-text').innerText);
            if(bio) document.getElementById('bio-text').innerText = bio;
        }

        function showDonate() {
            document.getElementById('overlay').style.display = 'block';
            document.getElementById('donateModal').style.display = 'block';
        }
        function closeModal() {
            document.getElementById('overlay').style.display = 'none';
            document.getElementById('donateModal').style.display = 'none';
        }

        /* 跳转到他人页面/品味 */
        function goToTaste() {
            const v = document.getElementById('otherLink').value.trim();
            if(!v) { alert('请输入对方的链接或用户名'); return; }
            // 防止再次跳转到当前页面（防止复制/二次跳转）
            const normalized = v.startsWith('/') ? v : ('/profile/' + encodeURIComponent(v));
            if (normalized === CURRENT_PROFILE_PATH) { alert('禁止再次跳转到当前主页'); return; }
            // 完整 http(s) 链接
            if(v.startsWith('http://') || v.startsWith('https://')) { window.open(v, '_blank'); return; }
            // 以 / 开头的内部路径
            if(v.startsWith('/')) { window.location.href = v; return; }
            // 否则当作用户名
            window.location.href = '/profile/' + encodeURIComponent(v);
        }

        /* 复制我的链接到剪贴板（前端实现） */
        function shareMyLink() {
            const link = document.getElementById('myShareLink').value;
            if(navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(link).then(function(){ alert('已复制到剪贴板'); }).catch(function(){ prompt('请手动复制链接：', link); });
            } else {
                prompt('请手动复制链接：', link);
            }
        }

        /* 设置是否公开歌单（仅自己可用） */
        function setPublicPlaylists(val) {
            fetch('/api/set_public_playlists', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ value: !!val })
            }).then(r=>r.json()).then(d=>{
                if(d && d.success) { alert('设置已保存'); }
                else { alert('保存失败'); document.getElementById('publicPlaylists').checked = !val; }
            }).catch(e=>{ alert('网络错误'); document.getElementById('publicPlaylists').checked = !val; });
        }

        // 图片修复
        document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll('.spotify-fix').forEach(img => {
                const title = img.getAttribute('data-title');
                const artist = img.getAttribute('data-artist');
                if (title && artist) {
                    const query = `title=${encodeURIComponent(title)}&artist=${encodeURIComponent(artist)}`;
                    fetch(`/api/cover_search?${query}`).then(r=>r.json()).then(d=>{if(d.url) img.src=d.url}).catch(e=>{});
                }
            });
        });
    </script>
</body>
</html>