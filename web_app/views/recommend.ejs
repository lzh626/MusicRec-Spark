<!DOCTYPE html>
<html>
<head>
    <title>专属每日推荐</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { 
            font-family: 'Segoe UI', sans-serif; margin: 0; padding: 40px; 
            background: #121212; color: white; min-height: 100vh;
            background-image: radial-gradient(circle at 50% 0, #1e3c72, #121212 60%);
        }
        .header { 
            text-align: center; margin-bottom: 40px; position: relative; 
            border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px;
        }
        .title { font-size: 32px; font-weight: bold; letter-spacing: 2px; }
        .subtitle { color: #888; font-size: 14px; margin-top: 5px; }
        
        .btn-action { 
            position: absolute; top: 5px; padding: 8px 20px; 
            border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.1); 
            border-radius: 30px; cursor: pointer; color: white; text-decoration: none; 
            font-size: 14px; transition: 0.3s; backdrop-filter: blur(5px);
        }
        .btn-action:hover { background: white; color: #121212; }
        .btn-left { left: 0; }
        .btn-right { right: 0; }

        .list-container { max-width: 800px; margin: 0 auto; position: relative; }
        
        .page { display: none; animation: fadeIn 0.5s; }
        .page.active { display: block; }
        
        .item { 
            display: flex; align-items: center; padding: 15px; margin-bottom: 15px;
            border-radius: 12px; cursor: pointer; transition: 0.2s; 
            text-decoration: none; color: inherit; 
            background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.05);
        }
        .item:hover { background: rgba(255,255,255,0.15); transform: translateX(10px); }
        
        .index { width: 40px; text-align: center; font-size: 20px; color: #31c27c; font-weight: bold; font-style: italic; }
        .cover { width: 60px; height: 60px; border-radius: 8px; object-fit: cover; margin: 0 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
        .info { flex: 1; }
        .song-title { font-weight: bold; font-size: 16px; margin-bottom: 5px; }
        .song-artist { font-size: 13px; color: #aaa; }
        .score { font-size: 12px; color: #31c27c; background: rgba(49, 194, 124, 0.1); padding: 4px 8px; border-radius: 10px; }

        .pagination { text-align: center; margin-top: 40px; }
        .page-dot { display: inline-block; width: 10px; height: 10px; background: #333; border-radius: 50%; margin: 0 5px; cursor: pointer; transition: 0.3s; }
        .page-dot.active { background: #31c27c; transform: scale(1.5); }

        @keyframes fadeIn { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="header">
        <a href="/" class="btn-action btn-left"><i class="fas fa-arrow-left"></i> 返回首页</a>
        <div class="title">最懂你的专属每日推荐</div>
        <div class="subtitle">Based on Spark ALS · 为您甄选 20 首</div>
        <a href="/recommend?refresh=true" class="btn-action btn-right"><i class="fas fa-sync-alt"></i> 重新计算</a>
    </div>

    <div class="list-container">
        <!-- 第一页：前10首 -->
        <div class="page active" id="page-1">
            <% songs.slice(0, 10).forEach(function(song, index) { %>
                <a href="/player/<%= song.song_id %>" class="item">
                    <div class="index"><%= index + 1 %></div>
                    <img src="<%= song.image_url %>" class="cover spotify-fix" 
                         data-source="<%= song.source %>" data-title="<%= song.title %>" data-artist="<%= song.artist %>"
                         onerror="this.src='https://y.qq.com/mediastyle/global/img/cover_like.png'">
                    <div class="info">
                        <div class="song-title"><%= song.title %></div>
                        <div class="song-artist"><%= song.artist %></div>
                    </div>
                    <div class="score">契合度 <%= (song.rank_score * 100).toFixed(0) %>%</div>
                </a>
            <% }); %>
        </div>

        <!-- 第二页：后10首 -->
        <div class="page" id="page-2">
            <% songs.slice(10, 20).forEach(function(song, index) { %>
                <a href="/player/<%= song.song_id %>" class="item">
                    <div class="index"><%= index + 11 %></div>
                    <img src="<%= song.image_url %>" class="cover spotify-fix" 
                         data-source="<%= song.source %>" data-title="<%= song.title %>" data-artist="<%= song.artist %>"
                         onerror="this.src='https://y.qq.com/mediastyle/global/img/cover_like.png'">
                    <div class="info">
                        <div class="song-title"><%= song.title %></div>
                        <div class="song-artist"><%= song.artist %></div>
                    </div>
                    <div class="score">契合度 <%= (song.rank_score * 100).toFixed(0) %>%</div>
                </a>
            <% }); %>
        </div>

        <div class="pagination">
            <span class="page-dot active" onclick="switchPage(1)"></span>
            <span class="page-dot" onclick="switchPage(2)"></span>
        </div>
    </div>

    <!-- 脚本：分页 + 图片修复 -->
    <script>
        function switchPage(p) {
            document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
            document.getElementById('page-' + p).classList.add('active');
            document.querySelectorAll('.page-dot').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.page-dot')[p-1].classList.add('active');
        }

        // 复用图片修复逻辑
        document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll('.spotify-fix').forEach(img => {
                const src = img.getAttribute('data-source');
                const title = img.getAttribute('data-title');
                const artist = img.getAttribute('data-artist');
                const currentUrl = img.getAttribute('src');
                if (src === 'spotify' && (!currentUrl || currentUrl.includes('cover_like') || currentUrl === 'null' || currentUrl === '')) {
                    const query = `title=${encodeURIComponent(title)}&artist=${encodeURIComponent(artist)}`;
                    fetch(`/api/cover_search?${query}`).then(r=>r.json()).then(d=>{if(d.url) img.src=d.url}).catch(e=>{});
                }
            });
        });
    </script>
</body>
</html>